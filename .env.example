# Copy to .env.local to override at build time.
#
# Public OAuth client IDs for the auto-backup destinations. PKCE OAuth has no
# client secret, so these IDs are public — safe to commit. Override per build
# by setting the env var in CI or a local .env.local file.

# Google Drive — Google Cloud Console → OAuth client ID (Web application).
VITE_GOOGLE_CLIENT_ID=

# Dropbox — Dropbox App Console → App key.
VITE_DROPBOX_APP_KEY=
